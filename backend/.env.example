# Copy to ".env" for local dev. On Vercel, set these in
# Project Settings -> Environment Variables (Production + Preview).

# --- Required: the app will not start without these ---
MONGO_URL=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/?retryWrites=true&w=majority
DB_NAME=rivaledge

# --- Strongly recommended: these have insecure defaults ---
JWT_SECRET=replace-with-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

# Comma-separated allowed origins. Defaults to "*".
CORS_ORIGINS=https://bfsi.vercel.app

# --- Optional ---
ADMIN_EMAIL=rivaledgeventuresinfo@gmail.com
EMAIL_FROM_NAME=RivalEdge Ventures
EMERGENT_EMAIL_KEY=

# Where uploaded resumes are written. Defaults to the system temp dir.
# Temp storage is wiped between requests on serverless hosts.
UPLOAD_DIR=
